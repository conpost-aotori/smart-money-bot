# Discord webhook for the daily snapshot post (REQUIRED unless DRY_RUN=true)
DISCORD_WEBHOOK_URL=

# Optional: separate channel for the daily snapshot. If unset, falls back
# to DISCORD_WEBHOOK_URL.
DAILY_SNAPSHOT_DISCORD_WEBHOOK_URL=

# X (Twitter) v2 OAuth1.0a user-context credentials. Required only if
# daily_snapshot.enable_x is true and you're not running --dry-run.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# Translation provider keys (only the one matching settings.yaml
# daily_snapshot.jp_translation_provider needs to be set):
#   gemini     → GEMINI_API_KEY (free tier 1500 RPD; aistudio.google.com/apikey)
#   anthropic  → ANTHROPIC_API_KEY (paid)
# If neither is set, the snapshot falls back to the raw ticker as the label.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: DeepL Free as automatic fallback when the primary LLM fails
# (rate limit / timeout). Plain translation only — missing the LLM's stylized
# qualifiers but better than English truncation. Free 500K chars/月.
# Sign up: https://www.deepl.com/pro-api → Free
DEEPL_API_KEY=

# Optional: identify your bot to Hyperliquid's public API (no key needed).
HYPERLIQUID_USER_AGENT=smart-money-bot/0.1
HYPERLIQUID_INFO_BASE=https://api.hyperliquid.xyz

LOG_LEVEL=INFO
DB_PATH=./data/smart_money.db
DRY_RUN=false
